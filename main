# main.py - CyberCrux OS Simulation Prototype
import time
import random
from modules.falcon_swarm import FalconSwarm
from modules.roe_amplifier import ROEAmplifier
from modules.nuke_orb import NukeOrb
from core.command_parser import parse_command

print("=== CYBERCRUX OS v1.0 MIL-GRADE SIMULATION ===")
print("Zero-Trust Kernel Initialized. Multimodal Interface Active.\n")

# Initialize modules
swarm = FalconSwarm(num_drones=48, theater="Ukraine")
roe = ROEAmplifier()
nuke_orb = NukeOrb()

current_dashboard = "🇺🇦 Ukraine"

while True:
    command = input(f"[{current_dashboard}] Kinetic Lead > ").strip().lower()
    
    if command == "exit":
        print("Shutting down CyberCrux OS... Simulation terminated.")
        break
    
    result = parse_command(command, swarm, roe, nuke_orb, current_dashboard)
    
    if "switch" in command and "usa" in command:
        current_dashboard = "🇺🇸 USA"
        print("Dashboard switched to USA variant.")
    elif "switch" in command and "france" in command:
        current_dashboard = "🇫🇷 France"
        print("Dashboard switched to France variant.")
    # Add more switches as needed
    
    print(result)
    time.sleep(0.5)
